# Required: Azure AD application (client) ID
# Register an app at https://portal.azure.com and copy the Application (client) ID here
VITE_AAD_CLIENT_ID=your-client-id-here

# Optional: Azure AD authority URL. Defaults to https://login.microsoftonline.com/common
# Set to a specific tenant ID to restrict sign-in to a single tenant:
# VITE_AAD_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# Optional: URL to redirect to after sign-out. Defaults to the app's origin.
# VITE_POST_LOGOUT_REDIRECT_URI=https://your-app-domain.example.com

# Optional: SKU variant to build. Defaults to 'edu'. Set to 'health' for the health SKU.
# VITE_SKU=edu
